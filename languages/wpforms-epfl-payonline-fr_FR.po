#. translators: %s - Addons page URL in admin area.
#: class-wpforms-epfl-payonline.php:739
msgid ""
"This addon allows to use <a href=\"%1$s\">EPFL Payonline</a> with the <a "
"href=\"%2$s\">WPForms plugin</a>. Please read <a href=\"%3$s\">Payonline "
"Help</a> in order to create a payment instance."
msgstr ""
"Ce module active l'utilisation d'<a href=\"%s\">EPFL Payonline</a> avec le "
"<a href=\"%s\">plugin WPForms</a>. Merci de lire <a href=\"%s\">l'aide "
"Payonline</a>."

#: class-wpforms-epfl-payonline.php:746
msgid "https://payonline.epfl.ch?lang=en"
msgstr "https://payonline.epfl.ch?lang=fr"

#: class-wpforms-epfl-payonline.php:748
msgid "https://wiki.epfl.ch/payonline-help"
msgstr "https://wiki.epfl.ch/payonline-aide"

